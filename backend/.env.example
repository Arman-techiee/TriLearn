# Runtime environment.
# Required. Use "development" for local Docker or local Node, "test" for tests, and "production" for deployed servers.
NODE_ENV=development

# HTTP port for the Express API.
# Required for Docker Compose port mapping and local development.
PORT=5000

# PostgreSQL connection string used by Prisma and the pg adapter.
# Required. In Docker Compose, this value is overridden from the root .env POSTGRES_* values.
DATABASE_URL=postgresql://CHANGE_USER:CHANGE_PASSWORD@localhost:5432/trilearn

# Redis connection string used for shared rate limiting, Socket.IO scaling, and BullMQ queues.
# Required for production. Recommended for Docker development.
REDIS_URL=redis://:CHANGE_PASSWORD@localhost:6379

# Access-token signing secret.
# Required. Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_64

# Refresh-token signing secret.
# Required. Generate a different value from JWT_ACCESS_SECRET.
JWT_REFRESH_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_64__DIFFERENT_FROM_ACCESS

# Secret used to sign login captcha challenges.
# Required. Generate a different value from the JWT secrets.
LOGIN_CAPTCHA_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_64

# Secret used to sign student ID QR codes.
# Required. Generate a different value from the JWT secrets.
QR_SIGNING_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_64

# Shared secret used to verify genuine mobile app requests.
# Generate with: openssl rand -hex 32
# Must match the value compiled into the mobile app.
MOBILE_CLIENT_SHARED_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_32

# Frontend origin used for CORS, password reset links, and Socket.IO browser connections.
# Required. Use a comma-separated list for multiple trusted origins.
FRONTEND_URL=http://localhost:5173

# Bcrypt salt rounds for password hashing.
# Required for predictable local config. Valid range is 10-16; defaults to 12 if invalid.
BCRYPT_ROUNDS=12

# Access and refresh token lifetimes.
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Optional: allow Socket.IO requests without an Origin header in local development only.
ALLOW_SOCKET_NO_ORIGIN=false

# Express trust proxy setting.
# - Leave blank for local development (defaults to 'loopback').
# - Set to 1 for Railway, Render, Fly.io, Heroku (single proxy layer).
# - Set to the load balancer IP/CIDR for self-hosted nginx/Caddy.
# - NEVER set to 'true' (trusts all IPs, enables X-Forwarded-For spoofing).
TRUST_PROXY=

# Optional: bearer token for external health checks.
HEALTHCHECK_KEY=

# Optional: Sentry error alerting. Leave SENTRY_DSN blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Allow public student intake form submissions. When false, the intake endpoint still works
# but coordinators must manually create student applications.
# WARNING: In production with this set to true, anyone can submit an application.
OPEN_REGISTRATION=false

# Timezone used by attendance day boundaries. Use Asia/Kathmandu for Nepal production deployments.
ATTENDANCE_TIMEZONE=Asia/Kathmandu
TZ=Asia/Kathmandu

# Optional: comma-separated kid:secret entries for QR signing key rotation.
QR_SIGNING_SECRET_KEYS=
QR_SIGNING_ACTIVE_KID=

# Firebase Cloud Messaging server key. Leave blank to disable push delivery locally.
FCM_SERVER_KEY=

# SMTP settings for password reset email delivery.
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_USER=resend
RESEND_SMTP_PASS=
# RESEND_SMTP_SECURE=false  # false = STARTTLS on port 587. Use true only for port 465 (SSL).

# Sender address for outgoing emails.
MAIL_FROM=TriLearn <no-reply@yourdomain.com>

# Enable password reset emails. Requires SMTP config.
ENABLE_PASSWORD_RESET=false

# Local troubleshooting ONLY. Never set to true in production — it leaks stack traces to clients.
# Blocked by validateEnv.js when NODE_ENV=production.
DEBUG_ERRORS=false

# Set to true to mount SwaggerUI at /api/docs (development only, requires authentication).
ENABLE_API_DOCS=false

# Disable Express rate limits in local development. Not allowed in production.
DISABLE_RATE_LIMITS=false

# Login rate limit settings.
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Background maintenance intervals in milliseconds.
REFRESH_TOKEN_CLEANUP_INTERVAL_MS=21600000
ATTENDANCE_SYNC_INTERVAL_MS=300000
AUDIT_LOG_CLEANUP_INTERVAL_MS=86400000

# Notification worker concurrency for BullMQ.
NOTIFICATION_WORKER_CONCURRENCY=2

# Audit log retention in days.
AUDIT_LOG_RETENTION_DAYS=180

# PDF upload size limits in bytes by role.
MAX_PDF_UPLOAD_BYTES_ADMIN=15728640
MAX_PDF_UPLOAD_BYTES_COORDINATOR=15728640
MAX_PDF_UPLOAD_BYTES_INSTRUCTOR=15728640
MAX_PDF_UPLOAD_BYTES_STUDENT=10485760

# Socket.IO per-user event rate limit settings.
SOCKET_EVENT_RATE_LIMIT_MAX=60
SOCKET_EVENT_RATE_LIMIT_WINDOW_MS=10000

# Prisma/PostgreSQL pool settings.
PGPOOL_MAX=10
PGPOOL_MIN=0
PGPOOL_IDLE_TIMEOUT_MS=10000
PGPOOL_CONNECTION_TIMEOUT_MS=10000
PGPOOL_MAX_USES=0

# Upload storage settings.
# If all required S3_* values are set, uploads are stored privately in S3/R2 and served with short-lived presigned URLs.
# If any required values are blank, uploads fall back to local disk for development only.
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PATH=/api/v1/uploads
# Optional public app-facing prefix for file records. Use a CloudFront/custom domain here to avoid exposing raw bucket hostnames.
UPLOAD_BASE_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Optional for S3-compatible providers such as Cloudflare R2.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PRESIGNED_URL_TTL_SECONDS=300

# DEFAULT_STUDENT_PASSWORD has been removed. A unique random password is generated for each new student account.
