# Production release example.
# Replace example.com with the deployed domains for the environment you are shipping.
# Do not build APK/IPA artifacts with localhost, private LAN IPs, or plain HTTP URLs.
EXPO_PUBLIC_API_URL=https://api.example.com/api/v1
EXPO_PUBLIC_SOCKET_URL=https://api.example.com
EXPO_PUBLIC_WEB_URL=https://app.example.com
EXPO_PUBLIC_MOBILE_CLIENT_SECRET=replace_with_mobile_client_shared_secret
