# TriLearn environment reference.
# Copy the variables needed by each runtime into that runtime's .env file:
# - Root Docker Compose: .env
# - Backend API: backend/.env
# - Frontend web app: frontend/.env
# - Mobile app: mobile/.env
#
# Generate real secrets with backend/scripts/gen-env.sh or:
# openssl rand -hex 64

# ---------------------------------------------------------------------------
# Root Docker Compose
# ---------------------------------------------------------------------------

POSTGRES_USER=trilearn_user
POSTGRES_PASSWORD=replace_with_local_postgres_password
REDIS_PASSWORD=replace_with_local_redis_password

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://trilearn_user:replace_with_local_postgres_password@localhost:5432/trilearn
DIRECT_URL=

REDIS_URL=redis://:replace_with_local_redis_password@localhost:6379

JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret_value
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret
LOGIN_CAPTCHA_SECRET=replace_with_different_64_byte_hex_secret
QR_SIGNING_SECRET=replace_with_different_64_byte_hex_secret

QR_SIGNING_SECRET_KEYS=
QR_SIGNING_ACTIVE_KID=

FRONTEND_URL=http://localhost:5173
BCRYPT_ROUNDS=12
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

ALLOW_SOCKET_NO_ORIGIN=false
TRUST_PROXY=
FORCE_HTTPS=false
HEALTHCHECK_KEY=
DEBUG_ERRORS=false
ENABLE_API_DOCS=false
DISABLE_RATE_LIMITS=false

LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
SOCKET_EVENT_RATE_LIMIT_MAX=60
SOCKET_EVENT_RATE_LIMIT_WINDOW_MS=10000

ATTENDANCE_TIMEZONE=Asia/Kathmandu
TZ=Asia/Kathmandu
ATTENDANCE_SYNC_INTERVAL_MS=300000

OPEN_REGISTRATION=false
ENABLE_PASSWORD_RESET=false

MOBILE_CLIENT_SHARED_SECRET=
MIN_MOBILE_VERSION=

FCM_SERVER_KEY=

RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_USER=resend
RESEND_SMTP_PASS=
RESEND_SMTP_SECURE=false
RESEND_API_KEY=
MAIL_FROM=TriLearn <no-reply@yourdomain.com>

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

PGPOOL_MAX=10
PGPOOL_MIN=0
PGPOOL_IDLE_TIMEOUT_MS=10000
PGPOOL_CONNECTION_TIMEOUT_MS=10000
PGPOOL_MAX_USES=0
PGSSL_REJECT_UNAUTHORIZED=false

UPLOAD_DIR=backend/uploads
UPLOAD_PUBLIC_PATH=/api/v1/uploads
UPLOAD_BASE_URL=

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PRESIGNED_URL_TTL_SECONDS=300

MAX_PDF_UPLOAD_BYTES_STUDENT=10485760
MAX_PDF_UPLOAD_BYTES_INSTRUCTOR=15728640
MAX_PDF_UPLOAD_BYTES_COORDINATOR=15728640
MAX_PDF_UPLOAD_BYTES_ADMIN=15728640

AUDIT_LOG_RETENTION_DAYS=180
AUDIT_LOG_CLEANUP_INTERVAL_MS=86400000
REFRESH_TOKEN_CLEANUP_INTERVAL_MS=21600000
NOTIFICATION_WORKER_CONCURRENCY=2

TEST_DATABASE_URL=

# ---------------------------------------------------------------------------
# Frontend Web App
# ---------------------------------------------------------------------------

VITE_API_URL=http://localhost:5000/api/v1

# ---------------------------------------------------------------------------
# Mobile App
# ---------------------------------------------------------------------------

EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000
EXPO_PUBLIC_WEB_URL=http://localhost:5173
EXPO_PUBLIC_MOBILE_CLIENT_SECRET=
